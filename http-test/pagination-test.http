# 分页测试：注册新用户 → 批量创建角色 → 试分页
#
# 玩法：从上往下依次跑
#   1. 跑 #0 注册 tester_page（可能 400 已存在，无所谓）
#   2. 跑 #1 登录拿 token
#   3. 跑 #2~#13 批量创建 12 个角色（够分 3 页验证）
#   4. 跑 #20~#25 各种分页参数对比

############################################
#  准备：新用户 + token
############################################

### 0. 注册 tester_page —— 期望 code=0；已存在则 400，无所谓
POST http://localhost:8000/api/auth/register
Content-Type: application/json

{
  "username": "tester_page",
  "password": "123456"
}

### 1. 登录 tester_page —— 自动捕获 token
POST http://localhost:8000/api/auth/login
Content-Type: application/json

{
  "username": "tester_page",
  "password": "123456"
}

> {%
client.global.set("token", response.body.data);
%}

############################################
#  批量创建 12 个角色（够分 3 页，pageSize=5 时）
############################################

### 2. 创建 - 今汐
POST http://localhost:8000/api/resonators
Content-Type: application/json
Authorization: Bearer {{token}}

{ "name": "今汐",   "element": "衍射", "star": 5, "level": 90, "resonanceChain": 6 }

### 3. 创建 - 长离
POST http://localhost:8000/api/resonators
Content-Type: application/json
Authorization: Bearer {{token}}

{ "name": "长离",   "element": "热熔", "star": 5, "level": 90, "resonanceChain": 5 }

### 4. 创建 - 椿
POST http://localhost:8000/api/resonators
Content-Type: application/json
Authorization: Bearer {{token}}

{ "name": "椿",     "element": "冷凝", "star": 5, "level": 80, "resonanceChain": 4 }

