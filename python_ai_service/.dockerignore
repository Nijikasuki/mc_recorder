# 虚拟环境 (本地装的, 容器里 builder 重新装)
.venv/

# Python 字节码缓存
__pycache__/
*.pyc
*.pyo
*$py.class

# 测试 / 缓存
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# 环境变量 (含密钥, 绝对不进镜像; 运行时通过 docker-compose env 注入)
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/

# 构建产物
build/
dist/
*.egg-info/

# 测试用例 (不进生产镜像)
http-test/

# Git
.git/
.gitignore
