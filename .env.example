# ============================================================
# 环境变量模板 — 部署用
#
# 用法:
#   1. 复制此文件为 .env (cp .env.example .env)
#   2. 把下面 xxx 替换成你的真实密钥
#   3. .env 已在 .gitignore, 不会进 git
#   4. docker-compose 自动读取同目录的 .env
# ============================================================

# 智谱 AI key (https://open.bigmodel.cn)
ZHIPU_API_KEY=xxx-replace-with-real-key

# GitHub PAT (调 GitHub API 用, 无 scope 也行)
GITHUB_TOKEN=ghp_xxx

# Tavily 搜索 key (https://tavily.com)
TAVILY_API_KEY=tvly-xxx

# JWT 签名密钥 (至少 32 字节字符串, 随便编)
JWT_SECRET=put-a-random-long-string-here-at-least-32-bytes

# 数据库密码 (可选, 不填用默认)
# MYSQL_PASSWORD=root123
# POSTGRES_PASSWORD=postgres
# RABBITMQ_PASSWORD=guest
